{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "saoshu/final_report",
  "title": "Final Report",
  "$defs": {
    "contextReference": {
      "type": "object",
      "properties": {
        "ref_id": {"type": "string"},
        "source_kind": {"type": "string"},
        "source_label": {"type": "string"},
        "batch_id": {"type": "string"},
        "anchor": {"type": "string"},
        "chapter_num": {"type": "integer"},
        "offset_hint": {"type": ["integer", "null"]},
        "chapter_title": {"type": "string"},
        "keyword": {"type": "string"},
        "snippet": {"type": "string"},
        "note": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "type": "object",
  "required": ["report_version", "novel", "scan", "thunder", "depression", "overall"],
  "properties": {
    "report_version": {"type": "string"},
    "generated_at": {"type": "string"},
    "novel": {"type": "object"},
    "scan": {
      "type": "object",
      "properties": {
        "sampling": {
          "type": "object",
          "properties": {
            "pipeline_mode": {"type": "string"},
            "coverage_mode": {"type": "string"},
            "coverage_template": {"type": "string"},
            "coverage_unit": {"type": "string"},
            "chapter_detect_used_mode": {"type": "string"},
            "serial_status": {"type": "string"},
            "sample_mode": {"type": "string"},
            "sample_strategy": {"type": "string"},
            "sample_level": {"type": "string"},
            "sample_level_effective": {"type": "string"},
            "sample_level_recommended": {"type": "string"},
            "total_batches": {"type": "integer"},
            "selected_batches": {"type": "integer"},
            "coverage_ratio": {"type": "number"},
            "coverage_gap_summary": {"type": "string"},
            "coverage_gap_risk_types": {"type": "array", "items": {"type": "string"}},
            "basis_lines": {"type": "array", "items": {"type": "string"}},
            "selection_reasons": {"type": "array", "items": {"type": "object"}}
          },
          "additionalProperties": true
        },
        "coverage_decision": {
          "type": "object",
          "properties": {
            "action": {"type": "string"},
            "confidence": {"type": "string"},
            "reason_codes": {"type": "array", "items": {"type": "string"}},
            "reason_lines": {"type": "array", "items": {"type": "string"}},
            "current_conclusion": {"type": "string"},
            "risk_if_not_upgraded": {"type": "string"},
            "upgrade_benefit": {"type": "string"},
            "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "metadata_summary": {"type": "object"},
    "thunder": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "depression": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "events": {
      "type": "object",
      "properties": {
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "defense_recommendation": {"type": "object"},
    "overall": {"type": "object"},
    "decision_summary": {
      "type": "object",
      "properties": {
        "supporting_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
      },
      "additionalProperties": true
    },
    "evidence_summary": {
      "type": "object",
      "properties": {
        "key_events": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        },
        "unresolved_risks": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        },
        "pending_clues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "deep_dive_summary": {"type": "object"},
    "newbie_card": {
      "type": "object",
      "properties": {
        "level": {"type": "string"},
        "label": {"type": "string"},
        "confidence": {"type": "string"},
        "headline": {"type": "string"},
        "bullets": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": true
    },
    "view_prefs": {
      "type": "object",
      "properties": {
        "default_view": {"type": "string"}
      },
      "additionalProperties": true
    },
    "risks_unconfirmed": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "context_references": {"type": "array", "items": {"$ref": "#/$defs/contextReference"}}
        },
        "additionalProperties": true
      }
    },
    "audit": {
      "type": "object",
      "properties": {
        "pipeline_state": {
          "type": "object",
          "properties": {
            "started_at": {"type": "string"},
            "finished_at": {"type": "string"},
            "steps": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "step": {"type": "string"},
                  "status": {"type": "string"},
                  "detail": {"type": "string"},
                  "at": {"type": "string"}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "term_wiki": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "term": {"type": "string"},
          "category": {"type": "string"},
          "definition": {"type": "string"},
          "risk_impact": {"type": "string"},
          "boundary": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "follow_up_questions": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": true
}
