{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "saoshu/batch",
  "title": "Batch",
  "type": "object",
  "required": ["batch_id", "range", "events", "thunder_hits", "depression_hits", "risk_unconfirmed"],
  "properties": {
    "batch_id": {"type": "string"},
    "range": {"type": "string"},
    "events": {"type": "array", "items": {"type": "string"}},
    "new_characters": {"type": "array"},
    "metadata": {
      "type": "object",
      "properties": {
        "chapter_title_scan": {
          "type": "object",
          "properties": {
            "score": {"type": "number"},
            "critical": {"type": "boolean"},
            "hit_chapter_count": {"type": "integer"},
            "risk_rules": {"type": "array", "items": {"type": "string"}},
            "depression_rules": {"type": "array", "items": {"type": "string"}},
            "hits": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "chapter_num": {"type": "integer"},
                  "chapter_title": {"type": "string"},
                  "type": {"type": "string"},
                  "rule": {"type": "string"},
                  "matched": {"type": "string"},
                  "weight": {"type": "number"},
                  "critical": {"type": "boolean"}
                },
                "additionalProperties": true
              }
            }
          },
          "additionalProperties": true
        }
      },
      "additionalProperties": true
    },
    "thunder_hits": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["rule", "summary", "evidence_level"],
        "properties": {
          "rule": {"type": "string"},
          "summary": {"type": "string"},
          "evidence_level": {"type": "string"},
          "anchor": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "depression_hits": {"type": "array", "items": {"type": "object"}},
    "risk_unconfirmed": {"type": "array", "items": {"type": "object"}},
    "event_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "event_id": {"type": "string"},
          "rule_candidate": {"type": "string"},
          "category": {"type": "string"},
          "status": {"type": "string"},
          "certainty": {"type": "string"},
          "confidence_score": {"type": "number"},
          "review_decision": {"type": "string"},
          "review_updated_at": {"type": "string"}
        },
        "additionalProperties": true
      }
    },
    "delta_relation": {"type": "array", "items": {"type": "object"}}
  },
  "additionalProperties": true
}
