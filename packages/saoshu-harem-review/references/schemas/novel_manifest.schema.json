{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "saoshu/novel_manifest",
  "title": "Novel Manifest",
  "type": "object",
  "required": ["input_txt", "output_dir"],
  "properties": {
    "input_txt": {"type": "string"},
    "output_dir": {"type": "string"},
    "title": {"type": "string"},
    "author": {"type": "string"},
    "tags": {"type": "string"},
    "target_defense": {"type": "string"},
    "batch_size": {"type": "integer", "minimum": 10},
    "overlap": {"type": "integer", "minimum": 0},
    "enrich_mode": {"type": "string", "enum": ["external", "fallback"]},
    "enricher_cmd": {"type": "string"},
    "pipeline_mode": {"type": "string", "enum": ["economy", "performance"]},
    "sample_mode": {"type": "string", "enum": ["fixed", "dynamic"]},
    "sample_count": {"type": "integer", "minimum": 3},
    "sample_level": {"type": "string", "enum": ["auto", "low", "medium", "high"]},
    "sample_min_count": {"type": "integer", "minimum": 0},
    "sample_max_count": {"type": "integer", "minimum": 0},
    "sample_strategy": {"type": "string", "enum": ["risk-aware", "uniform"]},
    "alias_map": {"type": "string"},
    "keyword_rules": {"type": "string"},
    "risk_question_pool": {"type": "string"},
    "wiki_dict": {"type": "string"},
    "db_mode": {"type": "string", "enum": ["none", "local", "external"]},
    "db_path": {"type": "string"},
    "db_ingest_cmd": {"type": "string"},
    "report_default_view": {"type": "string", "enum": ["newbie", "expert"]},
    "report_pdf": {"type": "boolean"},
    "report_pdf_output": {"type": "string"},
    "report_pdf_engine_cmd": {"type": "string"},
    "report_relation_graph": {"type": "boolean"},
    "report_relation_graph_output": {"type": "string"},
    "report_relation_top_chars": {"type": "integer", "minimum": 1},
    "report_relation_top_signals": {"type": "integer", "minimum": 1},
    "report_relation_min_edge_weight": {"type": "integer", "minimum": 1},
    "report_relation_max_links": {"type": "integer", "minimum": 0},
    "report_relation_min_name_freq": {"type": "integer", "minimum": 1}
  },
  "additionalProperties": true
}
